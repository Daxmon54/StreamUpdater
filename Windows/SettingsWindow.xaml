<Window x:Class="SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Instellingen" Height="572" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" MinWidth="560" MinHeight="480"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Common header: name + mode + watch file -->
        <GroupBox Grid.Row="0" Header="Algemeen">
            <Grid Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="Benaming" VerticalAlignment="Center" Margin="0,0,8,6" />
                <TextBox x:Name="TxtName" Grid.Column="1" Margin="0,0,12,6" />
                <TextBlock Text="Configuratie" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,6" />
                <ComboBox x:Name="CboMode" Grid.Column="3" Margin="0,0,0,6" SelectionChanged="OnModeChanged" />

                <TextBlock Text="Watch-bestand" Grid.Row="1" VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox x:Name="TxtWatch" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,8,0" />
                <Button Content="Bladeren…" Grid.Row="1" Grid.Column="3" Click="OnBrowseWatch" />
            </Grid>
        </GroupBox>

        <TabControl x:Name="Tabs" Grid.Row="1" Margin="0,10,0,10">
            <TabItem Header="Stream">
                <StackPanel Margin="12">
                    <TextBlock Text="Voor Icecast (mode 1) en Shoutcast (mode 3)." Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,0,0,10" />
                    <TextBlock Text="Adres" />
                    <TextBox x:Name="TxtStreamAddr" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Gebruiker" />
                            <TextBox x:Name="TxtStreamUser" Margin="0,0,0,8" />
                            <TextBlock Text="Paswoord" />
                            <TextBox x:Name="TxtStreamPass" Margin="0,0,0,8" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Poort" />
                            <TextBox x:Name="TxtStreamPort" Margin="0,0,0,8" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Mount" />
                    <TextBox x:Name="TxtStreamMount" />
                </StackPanel>
            </TabItem>

            <TabItem Header="RDS">
                <StackPanel Margin="12">
                    <TextBlock Text="Type Encoder" />
                    <ComboBox x:Name="CboRds" Margin="0,0,0,8" Width="200" HorizontalAlignment="Left" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Adres" />
                            <TextBox x:Name="TxtRdsAddr" Margin="0,0,0,8" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Poort" />
                            <TextBox x:Name="TxtRdsPort" Margin="0,0,0,8" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Gebruiker (enkel Database)" />
                    <TextBox x:Name="TxtRdsUser" Margin="0,0,0,8" />
                    <TextBlock Text="Paswoord" />
                    <TextBox x:Name="TxtRdsPass" Margin="0,0,0,8" />
                    <TextBlock Text="Databasenaam (enkel Database — MySQL/MariaDB)" />
                    <TextBox x:Name="TxtRdsDb" Margin="0,0,0,8" />
                    <Button x:Name="BtnTestDb" Content="Test DB-verbinding" Click="OnTestDb"
                            HorizontalAlignment="Left" MinWidth="150" Margin="0,0,0,8"
                            Background="{DynamicResource ControlBackgroundBrush}"
                            Foreground="{DynamicResource ForegroundBrush}" />
                    <CheckBox x:Name="ChkRdsRt" Content="RadioText (RT) verzenden" />
                    <CheckBox x:Name="ChkRdsPs" Content="Dynamic PS verzenden" />
                    <CheckBox x:Name="ChkRdsClock" Content="Klok synchroniseren" />
                    <TextBlock Text="PS-tekst" Margin="0,6,0,0" />
                    <TextBox x:Name="TxtRdsPsText" />
                </StackPanel>
            </TabItem>

            <TabItem Header="RadioPlayer">
                <StackPanel Margin="12">
                    <TextBlock Text="UID" />
                    <TextBox x:Name="TxtRpUid" Margin="0,0,0,8" />
                    <TextBlock Text="Ingest-URL" />
                    <TextBox x:Name="TxtRpIngest" Margin="0,0,0,8" />
                    <TextBlock Text="API-sleutel" />
                    <TextBox x:Name="TxtRpApiKey" Margin="0,0,0,8" />
                    <TextBlock Text="Gebruiker" />
                    <TextBox x:Name="TxtRpUser" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Website / FTP">
                <StackPanel Margin="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="FTP-adres" />
                            <TextBox x:Name="TxtFtpAddr" Margin="0,0,0,8" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Poort" />
                            <TextBox x:Name="TxtFtpPort" Margin="0,0,0,8" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Gebruiker" />
                    <TextBox x:Name="TxtFtpUser" Margin="0,0,0,8" />
                    <TextBlock Text="Paswoord" />
                    <TextBox x:Name="TxtFtpPass" Margin="0,0,0,8" />
                    <TextBlock Text="Externe map" />
                    <TextBox x:Name="TxtFtpRemote" Margin="0,0,0,8" />
                    <TextBlock Text="Prefix" />
                    <TextBox x:Name="TxtWebPrefix" Margin="0,0,0,8" />
                    <TextBlock Text="Bestandsnaam" />
                    <TextBox x:Name="TxtWebFile" />
                </StackPanel>
            </TabItem>

            <TabItem Header="BUTT">
                <StackPanel Margin="12">
                    <TextBlock Text="Bestand" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtButtFile" Margin="0,0,8,0" />
                        <Button Content="Bladeren…" Grid.Column="1" Click="OnBrowseButt" />
                    </Grid>
                    <CheckBox x:Name="ChkButtDelete" Content="Bestand wissen na verzending" />
                </StackPanel>
            </TabItem>

            <TabItem Header="DTS">
                <StackPanel Margin="12">
                    <TextBlock Text="URL" />
                    <TextBox x:Name="TxtDtsUrl" Margin="0,0,0,8" />
                    <TextBlock Text="Sleutel (key)" />
                    <TextBox x:Name="TxtDtsKey" Margin="0,0,0,8" />
                    <TextBlock Text="UID (cid)" />
                    <TextBox x:Name="TxtDtsUid" Margin="0,0,0,8" />
                    <TextBlock Text="Formaat" />
                    <TextBox x:Name="TxtDtsFormat" Margin="0,0,0,8" />
                    <TextBlock Text="Status" />
                    <TextBox x:Name="TxtDtsStatus" Margin="0,0,0,8" />
                    <TextBlock Text="Type" />
                    <TextBox x:Name="TxtDtsType" />
                </StackPanel>
            </TabItem>

            <TabItem Header="Info">
                <StackPanel Margin="12">
                    <TextBlock Text="Standaard-tekst (na time-out)" />
                    <TextBox x:Name="TxtDefaultText" Margin="0,0,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Vertraging (sec)" />
                            <TextBox x:Name="TxtDelay" Margin="0,0,0,8" />
                            <TextBlock Text="Negeer artiest" />
                            <TextBox x:Name="TxtSkip" Margin="0,0,0,8" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Time-out (sec)" />
                            <TextBox x:Name="TxtTimeOut" Margin="0,0,0,8" />
                            <TextBlock Text="Volgorde" />
                            <ComboBox x:Name="CboOrder" Margin="0,0,0,8" />
                        </StackPanel>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Scheidingsteken 1" />
                            <TextBox x:Name="TxtSep1" Width="60" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Scheidingsteken 2" />
                            <TextBox x:Name="TxtSep2" Width="60" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Grid>
                    <CheckBox x:Name="ChkReplaceAmp" Content="Vervang &amp; door -" Margin="0,10,0,0" />
                    <CheckBox x:Name="ChkNoAudio" Content="Geen audio-item" />
                    <CheckBox x:Name="ChkDebug" Content="Debugmodus (toon gedetailleerde foutinformatie)" Margin="0,10,0,0" />
                    <TextBlock Text="Bij een fout (bv. Shoutcast-update) wordt de volledige foutinformatie getoond."
                               Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap" Margin="22,0,0,0" />
                </StackPanel>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button x:Name="BtnTest" DockPanel.Dock="Left" Content="Test verzenden" Click="OnTest"
                    MinWidth="120"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource ForegroundBrush}" />
            <Button DockPanel.Dock="Right" Content="Annuleren" Click="OnCancel" IsCancel="True"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource ForegroundBrush}" />
            <Button DockPanel.Dock="Right" Content="OK" Click="OnOk" Margin="0,0,8,0" IsDefault="True" />
        </DockPanel>
    </Grid>
</Window>
