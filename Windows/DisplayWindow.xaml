<Window x:Class="DisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Infoweergave" Height="320" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Standaard-tekst" />
            <TextBox x:Name="TxtDefault" Margin="0,2,0,12" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Weergavetijd standaard-tekst (seconden)" />
                    <TextBox x:Name="TxtTimeout" Margin="0,2,0,12" />
                </StackPanel>
            </Grid>

            <CheckBox x:Name="ChkReplaceAmp" Content="Vervang &amp; door -" />
            <CheckBox x:Name="ChkNoAudio" Content="Geen audio-item verzenden" />
            <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="Na het verzenden van een nummer wordt na de weergavetijd automatisch de standaard-tekst verstuurd." />
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Click="OnOk" Margin="0,0,8,0" IsDefault="True" />
            <Button Content="Annuleren" Click="OnCancel" IsCancel="True"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource ForegroundBrush}" />
        </StackPanel>
    </Grid>
</Window>
